<?xml version="1.0" encoding="UTF-8"?>
<ApprovalProcess xmlns="http://soap.sforce.com/2006/04/metadata">
    <active>true</active>
    <allowRecall>false</allowRecall>
    <allowedSubmitters>
        <type>allInternalUsers</type>
    </allowedSubmitters>
    <allowedSubmitters>
        <type>owner</type>
    </allowedSubmitters>
    <approvalPageFields>
        <field>Name</field>
        <field>Booking__c</field>
        <field>Project_Name__c</field>
        <field>Approval_Status__c</field>
        <field>Owner</field>
    </approvalPageFields>
    <approvalStep>
        <allowDelegate>false</allowDelegate>
        <approvalActions>
            <action>
                <name>Email_Alert_for_L2_Approver</name>
                <type>Alert</type>
            </action>
            <action>
                <name>Update_RC_L2_Approval_Date</name>
                <type>FieldUpdate</type>
            </action>
            <action>
                <name>Update_Status_to_Approved_By_L2</name>
                <type>FieldUpdate</type>
            </action>
        </approvalActions>
        <assignedApprover>
            <approver>
                <name>Audit_Queue</name>
                <type>queue</type>
            </approver>
            <whenMultipleApprovers>FirstResponse</whenMultipleApprovers>
        </assignedApprover>
        <entryCriteria>
            <criteriaItems>
                <field>Referral_Credits__c.Approval_Status__c</field>
                <operation>equals</operation>
                <value>Submitted for L2 Approval</value>
            </criteriaItems>
        </entryCriteria>
        <ifCriteriaNotMet>RejectRecord</ifCriteriaNotMet>
        <label>RC  Approval For  Audit</label>
        <name>RC_Approval_For_Audit</name>
        <rejectionActions>
            <action>
                <name>Update_Status_To_Rejected_By_L2</name>
                <type>FieldUpdate</type>
            </action>
        </rejectionActions>
    </approvalStep>
    <emailTemplate>Referral_Credit_Template_Folder/RC_Email_For_Audit</emailTemplate>
    <enableMobileDeviceAccess>false</enableMobileDeviceAccess>
    <entryCriteria>
        <criteriaItems>
            <field>Referral_Credits__c.Approval_Status__c</field>
            <operation>equals</operation>
            <value>Approved by L1,Rejected by L2</value>
        </criteriaItems>
    </entryCriteria>
    <finalApprovalRecordLock>true</finalApprovalRecordLock>
    <finalRejectionRecordLock>false</finalRejectionRecordLock>
    <initialSubmissionActions>
        <action>
            <name>L2_Approval_Notification_To_BO</name>
            <type>Alert</type>
        </action>
        <action>
            <name>Update_Approval_Status_to_L2_submitted</name>
            <type>FieldUpdate</type>
        </action>
    </initialSubmissionActions>
    <label>Referral Credit Approval For  Audit</label>
    <processOrder>2</processOrder>
    <recordEditability>AdminOnly</recordEditability>
    <showApprovalHistory>false</showApprovalHistory>
</ApprovalProcess>
