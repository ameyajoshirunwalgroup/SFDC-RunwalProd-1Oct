     <tr>
        <td style="border:1px solid black;" colspan="2"><b>Grand Total</b></td>
        <td style="border:1px solid black;"><b>
        <apex:outputPanel rendered="{! relatedTo.RW_Booking__r.Quotation__r.Discount_Applied__c == true}">
            <apex:outputText value="{0, number, #,##,##,###}">
