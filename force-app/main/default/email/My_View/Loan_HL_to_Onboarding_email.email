<html>
<head>
<style>
table, th, td {
  border: 2px solid black;
  border-collapse: collapse;
}
</style>
</head>
<body>
Dear {!Loan__c.HL_RM_Name__c},
<br/><br/>
<table style="width:60%">
<tr>
        <td> Booking Lead </td>
        <td> {!Loan__c.RW_Booking__r.Name}  </td>
</tr>
<tr>
        <td> Name </td>
        <td> {!Loan__c.Name}  </td>
</tr>
<tr>
        <td> Flat No.</td>
        <td>{!Loan__c.RW_Booking__r.Flat_No__c}  </td>
</tr>
<tr>
        <td> Sanction Status</td>
        <td>{!Loan__c.RW_Sanction_Status__c}  </td>
</tr>
<tr>
        <td> Sanction Received Date</td>
        <td>{!Loan__c.RW_Sanction_Date__c}  </td>
</tr>
<tr>
        <td> Sanctioned Bank Name</td>
        <td>{!Loan__c.RW_Bank_Name__c}  </td>
</tr>
</table>
</body>
</html>