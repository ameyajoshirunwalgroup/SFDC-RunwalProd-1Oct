<messaging:emailTemplate subject="CP Submitted Invoice for Billing  - ( {!relatedto.CP_Name__c} )." recipientType="User" relatedToType="CP_Brokerage__c">
<messaging:htmlEmailBody >
<table id="main" border="0" width="50%" border-collapse="collapse">
            <tr><td> Dear {!relatedto.CP_Invoice_Approver_L1__r.Name}, </td></tr>
            <tr><td> &nbsp; </td></tr>
            </table>
<c:CPBrokerageInvoiceEmailToSubmitter ChannelPartnerId="{!relatedto.Id}"></c:CPBrokerageInvoiceEmailToSubmitter>
</messaging:htmlEmailBody>
</messaging:emailTemplate>