<messaging:emailTemplate subject="Required Approval for CP invoice billing  - ( {!relatedto.CP_Name__c} )." recipientType="User" relatedToType="Brokerage_Invoice__c">

<messaging:htmlEmailBody >
<table id="main" border="0" width="50%" border-collapse="collapse">
            <tr><td> Dear {!recipient.Name}, </td></tr>
            <tr><td> &nbsp; </td></tr>
            </table>
<c:CPInvoiceDueUploadEmail ChannelPartnerId="{!relatedto.Id}"></c:CPInvoiceDueUploadEmail>
</messaging:htmlEmailBody>
</messaging:emailTemplate>