<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>L2_Amount__c</fullName>
    <formula>IF(
    Total_Approved_Interest_Amount_Waived__c &gt;
    Project__r.Project_Location__r.Project_Lead_Amount__c,

    MIN(
        Total_Approved_Interest_Amount_Waived__c -
        Project__r.Project_Location__r.Project_Lead_Amount__c,

        Project__r.Project_Location__r.CRM_Head_Amount__c
    ),

    0
)</formula>
    <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
    <label>CRM Head Amount</label>
    <precision>18</precision>
    <required>false</required>
    <scale>2</scale>
    <trackHistory>false</trackHistory>
    <type>Currency</type>
</CustomField>
