    <textTemplates>
        <name>emailBodyForCustomer</name>
        <isViewedAsPlainText>false</isViewedAsPlainText>
        <text>&lt;p&gt;&lt;strong style=&quot;background-color: rgb(255, 255, 255); font-size: 16px; font-family: Aptos, Aptos_EmbeddedFont, Aptos_MSFontService, sans-serif; color: rgb(0, 0, 0);&quot;&gt;Dear Customer, Welcome to Runwal&amp;nbsp;family!&lt;/strong&gt;&lt;/p&gt;&lt;p&gt;&lt;strong style=&quot;background-color: rgb(255, 255, 255); font-size: 16px; font-family: Aptos, Aptos_EmbeddedFont, Aptos_MSFontService, sans-serif; color: rgb(0, 0, 0);&quot;&gt;Your booking has been registered on the system and is currently under validation stage. Request you to complete all other formalities to help us&amp;nbsp;&lt;/strong&gt;	&lt;strong style=&quot;background-color: rgb(255, 255, 255); font-size: 16px; font-family: Aptos, Aptos_EmbeddedFont, Aptos_MSFontService, sans-serif; color: rgb(0, 0, 0);&quot;&gt;finalizing&lt;/strong&gt;	&lt;strong style=&quot;background-color: rgb(255, 255, 255); font-size: 16px; font-family: Aptos, Aptos_EmbeddedFont, Aptos_MSFontService, sans-serif; color: rgb(0, 0, 0);&quot;&gt;&amp;nbsp;your booking.&lt;/strong&gt;&lt;/p&gt;</text>
    </textTemplates>
    <textTemplates>
        <name>emailBodyTemplates</name>
        <isViewedAsPlainText>false</isViewedAsPlainText>
        <text>&lt;p&gt;Hi,&lt;/p&gt;&lt;p&gt;A new unit has been marked as &lt;strong&gt;Blocked&lt;/strong&gt;. A Greeting Call task has been assigned to you.&lt;/p&gt;&lt;p&gt;&lt;strong&gt;Customer Details:&lt;/strong&gt;&lt;/p&gt;&lt;ul&gt;&lt;li&gt;&lt;strong&gt;Customer Name:&lt;/strong&gt; {!$Record.Opportunity__r.Name}&lt;/li&gt;&lt;li&gt;&lt;strong&gt;Project:&lt;/strong&gt; {!$Record.Opportunity__r.RW_Project__r.Name}&lt;/li&gt;&lt;li&gt;&lt;strong&gt;Unit Number:&lt;/strong&gt; {!$Record.Opportunity__r.RW_Project_Unit__r.Name}&lt;/li&gt;&lt;/ul&gt;&lt;p&gt;&lt;strong&gt;Process Requirement:&lt;/strong&gt;&lt;/p&gt;&lt;ol&gt;&lt;li&gt;You are required to initiate a &lt;strong&gt;3-way conference call&lt;/strong&gt; via the Salesforce Dialer.&lt;/li&gt;&lt;li&gt;Ensure the &lt;strong&gt;Sales Manager&lt;/strong&gt; is connected before adding the customer.&lt;/li&gt;&lt;li&gt;&lt;strong&gt;TAT:&lt;/strong&gt; This call must be completed by &lt;strong&gt;[Date/Time + 48 Hours]&lt;/strong&gt;.&lt;/li&gt;&lt;/ol&gt;&lt;p&gt;Please click the link below to access the record and initiate the call:&lt;/p&gt;&lt;p&gt;&lt;a href=&quot;https://runwal--fullcopy.sandbox.lightning.force.com/lightning/r/Greeting_Call__c/{!$Record.Id}/view&quot; rel=&quot;noopener noreferrer&quot; target=&quot;_blank&quot;&gt;https://runwal--fullcopy.sandbox.lightning.force.com/lightning/r/Greeting_Call__c/{!$Record.Id}/view&lt;/a&gt;&lt;/p&gt;&lt;p&gt;Happy Calling!&lt;/p&gt;</text>
    </textTemplates>
    <textTemplates>
